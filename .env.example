# Environment variables for LENS Meeting Intelligence
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here      # Only needed for hinglish mode

# ── Optional (override defaults) ──────────────────────────────────────────────
WHISPER_MODEL=small                          # tiny | base | small | medium | large
SARVAM_STT_MODEL=saaras:v2.5
MISTRAL_MODEL=mistral-small-latest

# ── Tuning ─────────────────────────────────────────────────────────────────────
AUDIO_CHUNK_MINUTES=20
RAG_TOP_K=4
SARVAM_MAX_WORKERS=4
